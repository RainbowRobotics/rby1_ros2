# Brake engagement status for the joint components
# Each array maps to the respective joints of that component.
# A value of True indicates the brake is engaged (holding / locked).
# A value of False indicates the brake is released (free to move / servo active).

# Joint brakes for the left arm
bool[] left_arm

# Joint brakes for the right arm
bool[] right_arm

# Joint brakes for the torso
bool[] torso

# Joint brakes for the head
bool[] head
 
