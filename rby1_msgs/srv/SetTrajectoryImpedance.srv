# SetTrajectoryImpedance.srv
# Enable or disable impedance mode for follow_joint_trajectory execution.
# When enabled, each waypoint is sent as JointImpedanceControlCommand
# instead of the default JointPositionCommand.
bool[] state

# Joint stiffness values [N·m/rad], ordered torso → right_arm → left_arm.
# Total size must match the sum of DOFs for all commanded parts.
# If empty and state=true, defaults to 100.0 for all joints.
float64[] torso_stiffness
float64[] right_arm_stiffness
float64[] left_arm_stiffness

# Damping ratio (dimensionless). Default: 1.0
float64[] damping_ratio

# Per-joint torque limit [N·m]. Default: 10.0
float64[] torque_limit
---
bool success
string message
